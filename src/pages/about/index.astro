---
import Layout from "@/layouts/Layout.astro";
import SectionContainer from "@/components/SectionContainer.astro";
import { Image } from "@astrojs/image/components";
import projectData from "@/data/projectData.json";
import FormattedDate from "../../src/components/FormattedDate.astro";
import { getCollection } from "astro:content";
import { Icon } from "astro-icon";
import getSortedTags from "@/utils/getSortedTags";
---

<Layout
    title="About - 16g"
    description="About"
>
    <div
        class="main-wrapper wrap-sm grid gap-16 px-8 md:gap-24 lg:gap-32 mx-auto"
    >
        <SectionContainer class="hero--container flex flex-col gap-8 mt-32"> 
            <div class="content-container">
                <div class="page-title--content max-w-[54rem] mb-8 lg:mb-4">
                    <h2
                        class="text-1g font-medium leading-8 lg:leading-10 tracking-wide lg:tracking-wide mb-2"
                    >
                        About
                    </h2>
                    
                    <h3 class="text-1g font-medium leading-8 lg:leading-10 tracking-wide lg:tracking-wide text-neutral-500 my-2">
                    16g?
                    </h3>
                    <span class="text-base text-neutral-500">
                      生活と好きなもの・ことについての記録
                    </span>

                    <h3 class="text-1g font-medium leading-8 lg:leading-10 tracking-wide lg:tracking-wide text-neutral-500 my-2">
                    SE
                    </h3>
                    <span class="text-base text-neutral-500">
                    東北出身 漫画が好き
                    </span>

                    </div>
                </div>
            </div>
        </SectionContainer>
    </div>
</Layout>